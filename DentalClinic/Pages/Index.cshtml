@page
@model DentalClinic.Pages.IndexModel
@{
    Layout = "_Layout";
    var completedToday = Model.TodayList.Count(a => a.Status == "Completed");
    var pendingToday = Model.TodayList.Count(a => a.Status != "Completed" && a.Status != "Cancelled");
    var completionPct = Model.TodayAppointments > 0
        ? (int)Math.Round((double)completedToday / Model.TodayAppointments * 100)
        : 0;
}

<div dir="rtl" style="padding: 1.5rem 0; font-family: inherit;">

    @* Topbar *@
    <div style="display:flex; align-items:center; justify-content:space-between; padding-bottom:1.25rem; border-bottom:1px solid #e5e7eb; margin-bottom:1.5rem;">
        <div style="display:flex; align-items:center; gap:10px;">
            <div style="width:38px; height:38px; border-radius:8px; background:#eff6ff; display:flex; align-items:center; justify-content:center; color:#2563eb; font-size:20px;">
                <i class="ti ti-stethoscope"></i>
            </div>
            <div>
                <div style="font-size:16px; font-weight:500; color:#111827;">عيادة الأسنان</div>
                <div style="font-size:12px; color:#9ca3af;">نظام إدارة العيادة</div>
            </div>
        </div>
        <div style="font-size:12px; color:#6b7280; background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px; padding:5px 12px;">
            <i class="ti ti-calendar" style="font-size:12px; margin-left:4px;"></i>
            @DateTime.Today.ToString("dddd، dd MMMM yyyy", new System.Globalization.CultureInfo("ar"))
        </div>
    </div>

    @* Stats *@
    <div style="font-size:11px; font-weight:500; color:#9ca3af; letter-spacing:0.06em; margin-bottom:10px;">إحصائيات عامة</div>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:1.5rem;">

        <div style="background:#fff; border:1px solid #e5e7eb; border-right:3px solid #2563eb; border-radius:0 12px 12px 0; padding:1rem 1.1rem;">
            <div style="color:#2563eb; font-size:18px; margin-bottom:8px;"><i class="ti ti-users"></i></div>
            <div style="font-size:28px; font-weight:500; color:#111827;">@Model.TotalPatients</div>
            <div style="font-size:12px; color:#9ca3af; margin-top:4px;">إجمالي المرضى</div>
        </div>

        <div style="background:#fff; border:1px solid #e5e7eb; border-right:3px solid #16a34a; border-radius:0 12px 12px 0; padding:1rem 1.1rem;">
            <div style="color:#16a34a; font-size:18px; margin-bottom:8px;"><i class="ti ti-calendar-check"></i></div>
            <div style="font-size:28px; font-weight:500; color:#111827;">@Model.TodayAppointments</div>
            <div style="font-size:12px; color:#9ca3af; margin-top:4px;">مواعيد اليوم</div>
            <div style="font-size:11px; color:#6b7280; margin-top:3px;">@completedToday منجزة · @pendingToday قادمة</div>
        </div>

        <div style="background:#fff; border:1px solid #e5e7eb; border-right:3px solid #d97706; border-radius:0 12px 12px 0; padding:1rem 1.1rem;">
            <div style="color:#d97706; font-size:18px; margin-bottom:8px;"><i class="ti ti-calendar"></i></div>
            <div style="font-size:28px; font-weight:500; color:#111827;">@Model.TotalAppointments</div>
            <div style="font-size:12px; color:#9ca3af; margin-top:4px;">إجمالي المواعيد</div>
            <div style="font-size:11px; color:#6b7280; margin-top:3px;">منذ البداية</div>
        </div>

    </div>

    @* Two columns *@
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:1.5rem;">

        @* Today appointments *@
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:1rem 1.1rem;">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
                <span style="font-size:13px; font-weight:500; color:#111827;">
                    <i class="ti ti-clock" style="font-size:14px; vertical-align:-2px; margin-left:5px;"></i>مواعيد اليوم
                </span>
                <a href="/TodayAppointments" style="font-size:11px; color:#2563eb; text-decoration:none;">عرض الكل</a>
            </div>

            @if (!Model.TodayList.Any())
            {
                <p style="font-size:13px; color:#9ca3af; text-align:center; padding:1rem 0;">لا توجد مواعيد اليوم</p>
            }
            else
            {
                @foreach (var appt in Model.TodayList.Take(5))
                {
                    var isPast = appt.AppointmentDate < DateTime.Now;

                    var badgeStyle = appt.Status switch
                    {
                        "Cancelled" => "background:#fee2e2; color:#b91c1c;",
                        _ => isPast ? "background:#dcfce7; color:#15803d;" : "background:#eff6ff; color:#1d4ed8;"
                    };
                    var badgeLabel = appt.Status switch
                    {
                        "Cancelled" => "ملغى",
                        _ => isPast ? "منجز" : "قادم"
                    };
                    <div style="display:flex; align-items:center; justify-content:space-between; padding:8px 0; border-bottom:1px solid #f3f4f6;">
                        <div>
                            <div style="font-size:13px; color:#111827;">@appt.PatientName</div>
                            <div style="font-size:11px; color:#9ca3af; margin-top:2px;">@appt.Time</div>
                        </div>
                        <span style="display:inline-block; padding:2px 8px; border-radius:20px; font-size:10px; font-weight:500; @badgeStyle">@badgeLabel</span>
                    </div>
                }
            }
        </div>

        @* Quick summary *@
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:1rem 1.1rem;">
            <div style="font-size:13px; font-weight:500; color:#111827; margin-bottom:12px;">
                <i class="ti ti-chart-bar" style="font-size:14px; vertical-align:-2px; margin-left:5px;"></i>ملخص سريع
            </div>

            <div style="display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid #f3f4f6;">
                <div style="width:8px; height:8px; border-radius:50%; background:#2563eb; flex-shrink:0;"></div>
                <span style="font-size:12px; color:#6b7280; flex:1;">مواعيد هذا الأسبوع</span>
                <span style="font-size:13px; font-weight:500; color:#111827;">@Model.WeekAppointments</span>
            </div>
           
            <div style="display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid #f3f4f6;">
                <div style="width:8px; height:8px; border-radius:50%; background:#d97706; flex-shrink:0;"></div>
                <span style="font-size:12px; color:#6b7280; flex:1;">نسبة الإنجاز اليوم</span>
                <span style="font-size:13px; font-weight:500; color:#111827;">@completionPct%</span>
            </div>
            <div style="display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid #f3f4f6;">
                <div style="width:8px; height:8px; border-radius:50%; background:#2563eb; flex-shrink:0;"></div>
                <span style="font-size:12px; color:#6b7280; flex:1;">متوسط مواعيد يومياً</span>
                <span style="font-size:13px; font-weight:500; color:#111827;">
                    @(Model.TotalAppointments > 0 ? Math.Round((double)Model.TotalAppointments / 30, 1) : 0)
                </span>
            </div>
            <div style="display:flex; align-items:center; gap:10px; padding:8px 0;">
                <div style="width:8px; height:8px; border-radius:50%; background:#d97706; flex-shrink:0;"></div>
                <span style="font-size:12px; color:#6b7280; flex:1;">مواعيد ملغاة اليوم</span>
                <span style="font-size:13px; font-weight:500; color:#111827;">@Model.CancelledToday</span>
            </div>
        </div>

    </div>

    @* Action buttons *@
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <a href="/Patients" style="padding:7px 16px; border-radius:6px; background:#2563eb; color:#fff; font-size:13px; text-decoration:none; display:flex; align-items:center; gap:6px;">
            <i class="ti ti-users" style="font-size:14px;"></i>إدارة المرضى
        </a>
    </div>

</div>