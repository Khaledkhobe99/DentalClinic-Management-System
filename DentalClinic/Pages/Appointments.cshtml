@page "{patientId:int}"
@model DentalClinic.Pages.AppointmentsModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <title>مواعيد المريض</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    @if (TempData["ErrorMessage"]?.ToString() == "conflict")
    {
        <div class="alert alert-danger alert-dismissible fade show mx-3 mt-3" role="alert">
            هذا الوقت محجوز مسبقاً، يرجى اختيار وقت آخر
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="container mt-5">
        <h1 class="mb-4 text-primary">🦷 مواعيد المريض: @Model.PatientName</h1>
        <a href="/Patients" class="btn btn-secondary mb-3">رجوع للمرضى</a>
        <div class="card mb-4 shadow">
            <div class="card-body">
                <h5 class="card-title">إضافة موعد جديد</h5>
                <form method="post" class="row g-3">
                    <div class="col-md-6">
                        <input type="datetime-local" name="AppointmentDate" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">إضافة</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead class="table-primary">
                        <tr>
                            <th>التاريخ</th>
                            <th>الحالة</th>
                            <th>خيارات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appointment in Model.Appointments)
                        {
                            <tr>
                                <td>@appointment.AppointmentDate.ToString("yyyy/MM/dd - hh:mm tt")</td>
                                <td>@appointment.Status</td>
                                <td>
                                    <form method="post" asp-page-handler="Delete" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete this appointment?');">
                                        <input type="hidden" name="id" value="@appointment.Id" />
                                        <input type="hidden" name="patientId" value="@appointment.PatientId" />
                                        <button type="submit" class="btn btn-danger btn-sm">حذف</button>
                                    </form>
                                    <button class="btn btn-warning btn-sm" onclick="toggleReschedule(@appointment.Id)">تأجيل</button>
                                    <div id="reschedule-@appointment.Id" style="display:none; margin-top:5px;">
                                        <form method="post" asp-page-handler="Reschedule" class="row g-2"
                                              onsubmit="return confirm('Are you sure you want to reschedule this appointment?');">
                                            <input type="hidden" name="id" value="@appointment.Id" />
                                            <input type="hidden" name="patientId" value="@appointment.PatientId" />
                                            <div class="col-8">
                                                <input type="datetime-local" name="NewDate" class="form-control form-control-sm" required />
                                            </div>
                                            <div class="col-4">
                                                <button type="submit" class="btn btn-success btn-sm w-100">حفظ</button>
                                            </div>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script>
        function toggleReschedule(id) {
            var div = document.getElementById('reschedule-' + id);
            div.style.display = div.style.display === 'none' ? 'block' : 'none';
        }
    </script>
</body>
</html>