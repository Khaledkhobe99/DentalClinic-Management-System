@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <title>🦷 عيادة الأسنان</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="navbar-nav me-auto">
            <a class="nav-link text-white" href="/Index">Dashboard</a>
            <a class="nav-link text-white" href="/Patients">Patients</a>
            <a class="nav-link text-white" href="/TodayAppointments">TodayAppointments</a>
        </div>
        @if (Context.Session.GetString("Username") != null)
        {
            <div class="d-flex align-items-center gap-3">
                <span class="text-white" style="font-size:13px;">
                    👤 @Context.Session.GetString("Username")
                </span>
                <form method="post" asp-page="/Index" asp-page-handler="Logout">
                    <button type="submit" class="btn btn-outline-light btn-sm">خروج</button>
                </form>
            </div>
        }
    </nav>
    <div class="container mt-4">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>