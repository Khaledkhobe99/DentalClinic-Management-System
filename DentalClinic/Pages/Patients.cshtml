@page
@model DentalClinic.Pages.PatientsModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
}
<h1 class="mb-4 text-primary">🦷 عيادة الأسنان</h1>
<div class="mb-3">
    <input type="text" id="searchInput" class="form-control" placeholder="Search..." onkeyup="searchPatient()" />
</div>
<div class="card mb-4 shadow">
    <div class="card-body">
        <h5 class="card-title">إضافة مريض جديد</h5>
        <form method="post" class="row g-3">
            <div class="col-md-4">
                <input type="text" name="Name" class="form-control" placeholder="اسم المريض" required />
            </div>
            <div class="col-md-4">
                <input type="text" name="Phone" class="form-control" placeholder="رقم الهاتف" required />
            </div>
            <div class="col-md-2">
                <input type="number" name="TotalAmount" class="form-control" placeholder="المبلغ الكلي" required />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">إضافة</button>
            </div>
        </form>
    </div>
</div>
<div class="card shadow">
    <div class="card-body">
        <h5 class="card-title">قائمة المرضى</h5>
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th>الاسم</th>
                    <th>الهاتف</th>
                    <th>المبلغ الكلي</th>
                    <th>خيارات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var patient in Model.Patients)
                {
                    <tr>
                        <td>
                            <a href="/Appointments/@patient.Id" class="text-decoration-none">@patient.Name</a>
                        </td>
                        <td>@patient.Phone</td>
                        <td>@patient.TotalAmount.ToString("F2")</td>
                        <td>
                            <a href="/Payments/@patient.Id" class="btn btn-success btn-sm">المدفوعات</a>
                            <form method="post" asp-page-handler="Delete" class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete this patient?');">
                                <input type="hidden" name="id" value="@patient.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">حذف</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<script>
    function searchPatient() {
        var input = document.getElementById('searchInput').value.toLowerCase();
        var rows = document.querySelectorAll('tbody tr');
        rows.forEach(function(row) {
            var name = row.cells[0].textContent.toLowerCase();
            var phone = row.cells[1].textContent.toLowerCase();
            if (name.includes(input) || phone.includes(input)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>