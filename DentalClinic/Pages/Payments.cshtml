@page "{patientId:int}"
@model DentalClinic.Pages.PaymentsModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
}

<h1 class="mb-4 text-primary">💰 مدفوعات المريض: @Model.Patient.Name</h1>
<a href="/Patients" class="btn btn-secondary mb-3">رجوع للمرضى</a>

@* بطاقات الملخص *@
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-primary shadow-sm">
            <div class="card-body text-center">
                <div class="text-muted mb-1">المبلغ الكلي</div>
                <div class="fs-4 fw-bold text-primary">@Model.Patient.TotalAmount.ToString("F2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-success shadow-sm">
            <div class="card-body text-center">
                <div class="text-muted mb-1">المدفوع</div>
                <div class="fs-4 fw-bold text-success">@Model.TotalPaid.ToString("F2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-danger shadow-sm">
            <div class="card-body text-center">
                <div class="text-muted mb-1">المتبقي</div>
                <div class="fs-4 fw-bold text-danger">@Model.Remaining.ToString("F2")</div>
            </div>
        </div>
    </div>
</div>

@* فورم إضافة دفعة *@
<div class="card mb-4 shadow">
    <div class="card-body">
        <h5 class="card-title">إضافة دفعة جديدة</h5>
        <form method="post" class="row g-3">
            <div class="col-md-4">
                <input type="number" name="Amount" class="form-control"
                       placeholder="المبلغ" step="0.01" min="0.01" required />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100">إضافة</button>
            </div>
        </form>
    </div>
</div>

@* جدول الدفعات *@
<div class="card shadow">
    <div class="card-body">
        <h5 class="card-title">سجل الدفعات</h5>
        <table class="table table-striped table-hover">
            <thead class="table-success">
                <tr>
                    <th>التاريخ</th>
                    <th>المبلغ</th>
                    <th>خيارات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model.Payments)
                {
                    <tr>
                        <td>@payment.PaymentDate.ToString("yyyy/MM/dd - hh:mm tt")</td>
                        <td class="text-success fw-bold">@payment.Amount.ToString("F2")</td>
                        <td>
                            <form method="post" asp-page-handler="Delete" class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete this payment?');">
                                <input type="hidden" name="id" value="@payment.Id" />
                                <input type="hidden" name="patientId" value="@Model.Patient.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">حذف</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>