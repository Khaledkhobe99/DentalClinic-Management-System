@page
@model DentalClinic.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <title>تسجيل الدخول — عيادة الأسنان</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            direction: rtl;
            font-family: inherit;
            background: linear-gradient(135deg, #1e40af 0%, #1d4ed8 40%, #0e7490 100%);
            padding: 2rem;
            position: relative;
            overflow: hidden;
        }

        .bg-circle1 {
            position: fixed;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            top: -100px;
            left: -100px;
        }

        .bg-circle2 {
            position: fixed;
            width: 250px;
            height: 250px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            bottom: -60px;
            right: -40px;
        }

        .bg-circle3 {
            position: fixed;
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: rgba(255,255,255,0.07);
            top: 60%;
            left: 10%;
        }

        .card {
            background: #fff;
            border-radius: 20px;
            width: 100%;
            max-width: 390px;
            padding: 2.25rem 2rem;
            position: relative;
            z-index: 1;
        }

        .logo-wrap {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .logo-icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: linear-gradient(135deg, #1d4ed8, #0e7490);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 28px;
            margin-bottom: 14px;
        }

        .logo-title {
            font-size: 18px;
            font-weight: 500;
            color: #111827;
        }

        .logo-sub {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 4px;
        }

        .divider {
            height: 1px;
            background: #f3f4f6;
            margin-bottom: 1.5rem;
        }

        .field-label {
            font-size: 12px;
            font-weight: 500;
            color: #374151;
            margin-bottom: 6px;
        }

        .field-wrap {
            margin-bottom: 1.1rem;
        }

        .field-icon-wrap {
            position: relative;
        }

        .field-input {
            width: 100%;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            padding: 10px 12px 10px 36px;
            font-size: 13px;
            color: #111827;
            outline: none;
            background: #f9fafb;
        }

            .field-input:focus {
                border-color: #1d4ed8;
                background: #fff;
            }

        .field-icon {
            position: absolute;
            left: 11px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 16px;
        }

        .btn-login {
            width: 100%;
            padding: 11px;
            background: linear-gradient(135deg, #1d4ed8, #0e7490);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            margin-top: 0.75rem;
        }

        .error-box {
            background: #fee2e2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 12px;
            color: #b91c1c;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .badge-wrap {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-bottom: 1.25rem;
        }

        .badge-item {
            background: #eff6ff;
            color: #1d4ed8;
            font-size: 11px;
            padding: 3px 10px;
            border-radius: 20px;
            border: 1px solid #bfdbfe;
        }

        .footer-note {
            text-align: center;
            font-size: 11px;
            color: #9ca3af;
            margin-top: 1.25rem;
        }
    </style>
</head>
<body>
    <div class="bg-circle1"></div>
    <div class="bg-circle2"></div>
    <div class="bg-circle3"></div>

    <div class="card">
        <div class="logo-wrap">
            <div class="logo-icon"><i class="ti ti-stethoscope"></i></div>
            <div class="logo-title">عيادة الأسنان</div>
            <div class="logo-sub">نظام إدارة العيادة</div>
        </div>

        <div class="badge-wrap">
            <span class="badge-item"><i class="ti ti-shield-check" style="font-size:11px; margin-left:3px;"></i>آمن</span>
            <span class="badge-item"><i class="ti ti-lock" style="font-size:11px; margin-left:3px;"></i>مشفّر</span>
        </div>

        <div class="divider"></div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error-box">
                <i class="ti ti-alert-circle" style="font-size:14px;"></i>
                @Model.ErrorMessage
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="field-wrap">
                <div class="field-label">اسم المستخدم</div>
                <div class="field-icon-wrap">
                    <input class="field-input" type="text" name="Username" placeholder="أدخل اسم المستخدم" required />
                    <i class="ti ti-user field-icon"></i>
                </div>
            </div>
            <div class="field-wrap">
                <div class="field-label">كلمة المرور</div>
                <div class="field-icon-wrap">
                    <input class="field-input" type="password" name="Password" placeholder="أدخل كلمة المرور" required />
                    <i class="ti ti-lock field-icon"></i>
                </div>
            </div>
            <button type="submit" class="btn-login">
                <i class="ti ti-login" style="font-size:15px; vertical-align:-2px; margin-left:6px;"></i>
                تسجيل الدخول
            </button>
        </form>

        <div class="footer-note">
            <i class="ti ti-heart" style="font-size:11px; color:#e11d48;"></i>
            نظام مخصص لرعاية مرضى عيادة الأسنان
        </div>
    </div>
</body>
</html>